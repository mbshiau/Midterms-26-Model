DATABASE_URL=postgresql://forecast:forecast@localhost:5432/pa_gov_forecast
RECENCY_HALF_LIFE_DAYS=21
HISTORICAL_ERROR_STDEV=4.0
DEFAULT_N_SIMULATIONS=10000
CORS_ORIGINS=http://localhost:5173

# Kalshi account credentials (Account Settings -> API Keys on kalshi.com).
# Never commit real values here. The private key file itself goes in
# backend/secrets/ (gitignored) -- when running via Docker Compose, that
# directory is mounted read-only at /run/secrets, so point the path there;
# when running locally (no Docker), point it at wherever you saved the file
# on your own machine.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem

# UF Navigator API key (Race Intelligence section's AI news summary, AI
# market analysis, and per-article relevance blurbs -- a separate
# integration from Anthropic/Claude). An OpenAI-compatible endpoint, so any
# other OpenAI-compatible provider works too by swapping the base URL/model.
# Left blank, the AI text just never populates rather than erroring.
UF_NAVIGATOR_API_KEY=
UF_NAVIGATOR_BASE_URL=https://api.ai.it.ufl.edu/v1
UF_NAVIGATOR_MODEL=gpt-oss-120b
# Pace between calls so a scheduled refresh (which can make dozens of calls
# across every race) doesn't get rate-limited. Lower this if you observe
# UF Navigator tolerates faster requests.
AI_MIN_SECONDS_BETWEEN_CALLS=2
