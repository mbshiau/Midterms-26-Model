DATABASE_URL=postgresql://forecast:forecast@localhost:5432/pa_gov_forecast
RECENCY_HALF_LIFE_DAYS=21
HISTORICAL_ERROR_STDEV=4.0
DEFAULT_N_SIMULATIONS=10000
CORS_ORIGINS=http://localhost:5173

# Kalshi account credentials (Account Settings -> API Keys on kalshi.com).
# Never commit real values here. The private key file itself goes in
# backend/secrets/ (gitignored) -- when running via Docker Compose, that
# directory is mounted read-only at /run/secrets, so point the path there;
# when running locally (no Docker), point it at wherever you saved the file
# on your own machine.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem
